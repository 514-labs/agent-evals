          "id": "item_13",
          "type": "command_execution",
          "command": "/bin/bash -lc \"cat <<'PY' >/tmp/clean_events.py\nimport csv\nfrom datetime import datetime\nfrom pathlib import Path\n\nINPUT_DIR = Path(\\\"/data/csv\\\")\nOUTPUT_FILE = Path(\\\"/tmp/clean_events.csv\\\")\nEXPECTED_HEADERS = [\\\"event_id\\\", \\\"event_ts\\\", \\\"user_id\\\", \\\"event_type\\\", \\\"value\\\"]\nHEADER_VARIANTS = {\n    tuple(EXPECTED_HEADERS): EXPECTED_HEADERS,\n    tuple(EXPECTED_HEADERS + [\\\"\\\"]): EXPECTED_HEADERS,\n}\n\n\ndef normalize_timestamp(raw_ts: str) -> str:\n    raw = raw_ts.strip()\n    if not raw:\n        raise ValueError(\\\"Missing timestamp\\\")\n    if \\\"/\\\" in raw:\n        parsed = datetime.strptime(raw, \\\"%d/%m/%Y\\\")\n    else:\n        parsed = datetime.strptime(raw.replace(\\\"T\\\", \\\" \\\").replace(\\\"Z\\\", \\\"\\\"), \\\"%Y-%m-%d %H:%M:%S\\\")\n    return parsed.strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\n\n\ndef normalize_value(raw_value: str) -> str:\n    raw = raw.strip()\n    if raw in {\\\"\\\", \\\"N/A\\\", \\\"null\\\", \\\"NULL\\\"}:\n        return \\\"\\\\\\\\N\\\"\n    return raw\n\n\ndef normalize_row(row: list[str]) -> dict[str, str]:\n    padded = row + [\\\"\\\"] * (len(EXPECTED_HEADERS) - len(row))\n    trimmed = padded[: len(EXPECTED_HEADERS)]\n    normalized = dict(zip(EXPECTED_HEADERS, trimmed))\n    normalized[\\\"event_ts\\\"] = normalize_timestamp(normalized[\\\"event_ts\\\"])\n    normalized[\\\"value\\\"] = normalize_value(normalized[\\\"value\\\"])\n    return normalized\n\n\ndef is_duplicate_header(row: list[str]) -> bool:\n    return tuple([cell.strip() for cell in row if cell.strip()]) == tuple(EXPECTED_HEADERS)\n\n\ndef main() -> None:\n    files = sorted(INPUT_DIR.glob(\\\"events_*.csv\\\"))\n    seen = set()\n    with OUTPUT_FILE.open(\\\"w\\\", newline=\\\"\\\") as out:\n        writer = csv.DictWriter(out, fieldnames=EXPECTED_HEADERS)\n        writer.writeheader()\n        for path in files:\n            with path.open(\\\"r\\\", newline=\\\"\\\") as inp:\n                reader = csv.reader(inp)\n                for row in reader:\n                    if not row:\n                        continue\n                    if is_duplicate_header(row):\n                        continue\n                    row = [cell.strip() for cell in row]\n                    if not row[0]:\n                        continue\n                    normalized = normalize_row(row)\n                    if normalized[\\\"event_id\\\"] in seen:\n                        continue\n                    seen.add(normalized[\\\"event_id\\\"])\n                    writer.writerow(normalized)\n\n\nif __name__ == \\\"__main__\\\":\n    main()\nPY\"",
          "aggregated_output": "",
